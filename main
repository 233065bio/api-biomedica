    ecg: float
    spo2: float
    acc_x: float
    acc_y: float
    acc_z: float
    giro_x: float
    giro_y: float
    giro_z: float
    flujo_respiratorio: float # <--- Añadido

# 2. Actualiza la función de subir-datos
